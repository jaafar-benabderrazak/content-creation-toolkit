# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# ---- Content Creation Toolkit — Shared Layer ----
# Credentials and secrets (never commit)
credentials/*
!credentials/.gitkeep
.secrets/
*.pickle
client_secrets.json
youtube_token.json
token.json
.env
.env.*
!.env.example

# User-saved run configs (gitignore but keep .gitkeep)
configs/*
!configs/.gitkeep

# Approval gate marker files
*.approved

# Generated output directories (large binary files)
out/
tmp/
generated/
